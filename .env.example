HOST=0.0.0.0
PORT=8765
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

OLLAMA_BASE=http://127.0.0.1:11434

# ── Model Configuration ──
# Primary model: qwen3:8b is recommended (128K context, reasoning mode, 2025 training data)
# Alternatives: mistral:7b (32K ctx, older), llama3:8b-instruct (8K ctx, large community)
CHAT_MODEL=qwen3:8b
# Optional fast model for classification/simple tasks (empty = use CHAT_MODEL for everything)
# Recommended: phi4-mini (~3 GB VRAM, blazing fast, great for quick lookups)
# FAST_MODEL=phi4-mini
EMBED_MODEL=nomic-embed-text
# Embedding context (nomic-embed-text max train ctx = 2048). 0 = let Ollama default.
OLLAMA_EMBED_NUM_CTX=2048
# true = run embedder on CPU/RAM so chat model stays on GPU (good for 8GB VRAM + plenty of system RAM).
OLLAMA_EMBED_ON_CPU=true

# Context / generation limits (Qwen3:8B supports up to 128K, but 16K is a good default for 8GB VRAM)
# OLLAMA_CHAT_NUM_CTX=16384
# OLLAMA_CHAT_NUM_PREDICT=4096
# AGENT_OBSERVATION_MAX_CHARS=8000
# AGENT_ASSISTANT_MESSAGE_MAX_CHARS=12000
# AGENT_MAX_STEPS=8

# ── Ollama Performance (set as SYSTEM environment variables for best results) ──
# Enable flash attention (faster inference, required for KV cache quantization):
#   setx OLLAMA_FLASH_ATTENTION 1
# Quantize KV cache to halve VRAM usage (allows longer context in 8GB):
#   setx OLLAMA_KV_CACHE_TYPE q8_0
# For even more savings (slight quality trade-off):
#   setx OLLAMA_KV_CACHE_TYPE q4_0

# Optional: heavy node (Skye) for escalation on low-confidence answers
SKYE_URL=
SKYE_MODEL=mistral-small:22b

# Optional: SearXNG (self-hosted). When set, it replaces the Google+DDG path for web_search.
SEARXNG_URL=
# Google Programmable Search (Custom Search JSON API) — primary web results when both are set; DuckDuckGo fills gaps if WEB_SEARCH_FALLBACK_DDG=true
# Create engine: https://programmablesearchengine.google.com/ — enable Custom Search API in Google Cloud.
# GOOGLE_CSE_API_KEY=
# GOOGLE_CSE_CX=
# WEB_SEARCH_FALLBACK_DDG=true
# Auto-fetch top result pages during web_search (saves agent steps)
# WEB_SEARCH_AUTO_FETCH=true
# WEB_SEARCH_AUTO_FETCH_MAX=2
# WEB_SEARCH_AUTO_FETCH_CHARS=3000

# Optional: Discord bot HTTP tool + scripts/discord_bot.py
DISCORD_TOKEN=
DISCORD_GUILD_ID=0
DISCORD_CHANNEL_ID=0

# Memory ranking (weights sum is normalized at runtime)
# MEMORY_W_SIM=0.45
# MEMORY_W_IMP=0.20
# MEMORY_W_REC=0.20
# MEMORY_W_BOOST=0.15
# MEMORY_RECENCY_HALF_LIFE_DAYS=14

# Neuro-symbolic YAML hints (merged with packaged defaults)
# SYMBOLIC_ENABLED=true
# SYMBOLIC_RULES_PATH=./data/rules.yaml

# Reflection (multi-pass sampling + confidence gate)
# REFLECTION_MIN_CONFIDENCE=0.35
# REFLECTION_COMPARE_PREVIOUS=true

# Web UI (optional; usually in web/.env.local)
# NEXT_PUBLIC_PARADOX_API=http://127.0.0.1:8765
# Legacy aliases still supported: NEXT_PUBLIC_HEX_API, NEXT_PUBLIC_ANTON_API

# Discord script base URL (optional)
# PARADOX_API=http://127.0.0.1:8765

# ── EEG Research ──
# EEG_DOMAIN_ENABLED=true
# EEG_WORKSPACE=./data/eeg_workspace
# PYTHON_ANALYSIS_TIMEOUT=300
# AGENT_MAX_STEPS=8

# Data paths (defaults under ./data)
# CHROMA_PATH=
# VAULT_PATH=
# INGEST_QUEUE=

# ── Recommended Model Setup (run these in PowerShell) ──
# Primary reasoning model (best all-rounder for research):
#   ollama pull qwen3:8b
# Coding-focused model (swap in for code-heavy work):
#   ollama pull qwen2.5-coder:7b
# Fast lightweight model (for routing / autocomplete):
#   ollama pull phi4-mini
# Embeddings:
#   ollama pull nomic-embed-text
